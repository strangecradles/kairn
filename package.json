{
  "name": "kairn-cli",
  "version": "2.13.0",
  "description": "Compile natural language intent into optimized Claude Code environments",
  "author": "Ashton Perlroth",
  "license": "MIT",
  "type": "module",
  "bin": {
    "kairn": "bin/kairn.js"
  },
  "files": [
    "bin/",
    "dist/",
    "src/registry/tools.json",
    "src/registry/templates/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "claude",
    "ai",
    "agent",
    "environment",
    "mcp",
    "cli",
    "harness",
    "llm",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashtonperlroth/kairn.git"
  },
  "homepage": "https://github.com/ashtonperlroth/kairn#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.0.0",
    "commander": "^13.0.0",
    "kairn-cli": "^1.7.0",
    "openai": "^6.33.0",
    "ora": "^9.3.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
